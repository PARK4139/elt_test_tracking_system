<script>
(() => {
    const admin_grid_table = document.getElementById("admin_grid_table");
    if (!admin_grid_table) {
        return;
    }
    const header_cells = Array.from(admin_grid_table.querySelectorAll("thead th"));
    const resize_min_width = 24;
    let active_header_cell = null;
    let active_min_width = resize_min_width;
    let start_x = 0;
    let start_width = 0;
    const table_rows = Array.from(admin_grid_table.querySelectorAll("tbody tr"));
    const measure_canvas = document.createElement("canvas");
    const measure_context = measure_canvas.getContext("2d");
    const input_fill_ratio = 0.9;
    const text_inner_padding = 8;
    const cell_horizontal_padding = 8;

    const measure_text_width = (text) => {
        const normalized_text = String(text || "");
        if (!measure_context) {
            return Math.max(16, normalized_text.length * 8 + text_inner_padding);
        }
        measure_context.font = getComputedStyle(admin_grid_table).font || "400 18px pretendard";
        const measured_width = measure_context.measureText(normalized_text).width;
        return Math.max(16, Math.ceil(measured_width) + text_inner_padding);
    };

    const get_header_min_width = (header_cell) => {
        const header_label = String(header_cell.textContent || "").trim();
        return Math.max(resize_min_width, measure_text_width(header_label));
    };

    const get_cell_preferred_width = (cell) => {
        const input_or_select = cell.querySelector("input, select");
        if (input_or_select) {
            const value_text =
                input_or_select.tagName === "SELECT"
                    ? (input_or_select.options[input_or_select.selectedIndex]?.text || "")
                    : (input_or_select.value || input_or_select.placeholder || "");
            if (!String(value_text || "").trim()) {
                return 0;
            }
            const control_required_width = measure_text_width(value_text) + cell_horizontal_padding;
            return Math.ceil(control_required_width / input_fill_ratio);
        }
        return measure_text_width(cell.textContent || "") + cell_horizontal_padding;
    };

    const apply_auto_fit_column_widths = () => {
        header_cells.forEach((header_cell, column_index) => {
            if (header_cell.classList.contains("hidden_id_column") || header_cell.classList.contains("hidden_audit_column")) {
                return;
            }
            let preferred_width = measure_text_width(header_cell.textContent || "") + cell_horizontal_padding;
            table_rows.forEach((row) => {
                const cell = row.children[column_index];
                if (!cell) {
                    return;
                }
                preferred_width = Math.max(preferred_width, get_cell_preferred_width(cell));
            });
            const next_width = Math.max(get_header_min_width(header_cell), Math.ceil(preferred_width));
            header_cell.style.width = `${next_width}px`;
            header_cell.style.minWidth = `${next_width}px`;
        });
    };

    const on_mouse_move = (event) => {
        if (!active_header_cell) {
            return;
        }
        const delta_x = event.clientX - start_x;
        const next_width = Math.max(active_min_width, start_width + delta_x);
        active_header_cell.style.width = `${next_width}px`;
        active_header_cell.style.minWidth = `${next_width}px`;
    };

    const on_mouse_up = () => {
        active_header_cell = null;
        document.body.style.cursor = "";
        document.body.style.userSelect = "";
        window.removeEventListener("mousemove", on_mouse_move);
        window.removeEventListener("mouseup", on_mouse_up);
    };

    header_cells.forEach((header_cell) => {
        if (header_cell.classList.contains("hidden_id_column") || header_cell.classList.contains("hidden_audit_column")) {
            return;
        }
        const handle = document.createElement("span");
        handle.className = "column_resize_handle";
        handle.addEventListener("mousedown", (event) => {
            event.preventDefault();
            active_header_cell = header_cell;
            active_min_width = get_header_min_width(header_cell);
            start_x = event.clientX;
            start_width = header_cell.getBoundingClientRect().width;
            document.body.style.cursor = "col-resize";
            document.body.style.userSelect = "none";
            window.addEventListener("mousemove", on_mouse_move);
            window.addEventListener("mouseup", on_mouse_up);
        });
        header_cell.appendChild(handle);
    });
    apply_auto_fit_column_widths();
})();
</script>
<script>
(() => {
    const modal_overlay = document.getElementById("admin_guide_modal");
    const open_button = document.getElementById("open_admin_guide_modal_button");
    const close_button = document.getElementById("close_admin_guide_modal_button");
    const admin_feature_storage_key = "admin_feature_target_v1";
    if (!modal_overlay || !open_button || !close_button) {
        return;
    }

    const apply_feature_filter = (feature_target) => {
        const feature_sessions = Array.from(
            document.querySelectorAll("[data-admin-feature-session]")
        );
        let matched_count = 0;
        feature_sessions.forEach((section) => {
            const section_target = section.dataset.adminFeatureSession || "";
            if (feature_target === "all") {
                section.style.display = "block";
                return;
            }
            const is_match = section_target === feature_target;
            section.style.display = is_match ? "block" : "none";
            if (is_match) {
                matched_count += 1;
            }
        });
        return matched_count;
    };
    window.apply_admin_feature_filter = apply_feature_filter;

    const open_modal = () => {
        modal_overlay.classList.add("is_open");
        modal_overlay.setAttribute("aria-hidden", "false");
    };
    const close_modal = () => {
        modal_overlay.classList.remove("is_open");
        modal_overlay.setAttribute("aria-hidden", "true");
    };
    open_button.addEventListener("click", open_modal);
    close_button.addEventListener("click", close_modal);
    modal_overlay.addEventListener("click", (event) => {
        if (event.target === modal_overlay) {
            close_modal();
        }
    });
    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
            close_modal();
        }
    });

    document.querySelectorAll(".admin_feature_filter_button").forEach((button) => {
        button.addEventListener("click", () => {
            const feature_target = button.dataset.featureTarget || "all";
            const matched_count = apply_feature_filter(feature_target);
            if (feature_target !== "all" && matched_count === 0) {
                alert("현재 모드에서 해당 기능 세션을 표시할 수 없습니다.");
                localStorage.setItem(admin_feature_storage_key, "__none__");
                apply_feature_filter("__none__");
                close_modal();
                return;
            }
            localStorage.setItem(admin_feature_storage_key, feature_target);
            close_modal();
        });
    });

    const initial_feature_target = localStorage.getItem(admin_feature_storage_key) || "__none__";
    const initial_matched_count = apply_feature_filter(initial_feature_target);
    if (initial_feature_target !== "__none__" && initial_feature_target !== "all" && initial_matched_count === 0) {
        localStorage.setItem(admin_feature_storage_key, "__none__");
        apply_feature_filter("__none__");
    }
})();
</script>
<script>
(() => {
    const review_button = document.getElementById("admin_mark_review_complete_button");
    const delete_button = document.getElementById("admin_delete_selected_rows_button");
    if (!review_button || !delete_button) {
        return;
    }

    const read_error_detail = async (response) => {
        try {
            const payload = await response.json();
            if (payload && payload.detail) {
                return payload.detail;
            }
        } catch (_error) {
        }
        return "요청에 실패했습니다.";
    };

    const collect_selected_row_ids = () => {
        const checked_checkboxes = Array.from(
            document.querySelectorAll(".admin_row_select_checkbox:checked")
        );
        if (checked_checkboxes.length === 0) {
            return [];
        }
        return checked_checkboxes
            .map((checkbox) => checkbox.closest("tr"))
            .filter((row) => row && row.dataset.id)
            .map((row) => Number(row.dataset.id))
            .filter((row_id) => Number.isInteger(row_id) && row_id > 0);
    };

    review_button.addEventListener("click", async () => {
        const selected_row_ids = collect_selected_row_ids();
        if (selected_row_ids.length === 0) {
            alert("선택한 행이 없습니다.");
            return;
        }
        try {
            const response = await fetch("/admin/rows/review_complete", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ row_ids: selected_row_ids }),
            });
            if (!response.ok) {
                alert(await read_error_detail(response));
                return;
            }
            window.location.reload();
        } catch (_error) {
            alert("입력승인 처리 중 네트워크 오류가 발생했습니다.");
        }
    });

    delete_button.addEventListener("click", async () => {
        const delete_row_ids = collect_selected_row_ids();
        if (delete_row_ids.length === 0) {
            alert("선택한 행이 없습니다.");
            return;
        }
        if (delete_row_ids.length === 0) {
            alert("삭제 가능한 행 ID가 없습니다.");
            return;
        }

        try {
            const response = await fetch("/tester/rows/delete", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ row_ids: delete_row_ids }),
            });
            if (!response.ok) {
                alert(await read_error_detail(response));
                return;
            }
            window.location.reload();
        } catch (_error) {
            alert("삭제 중 네트워크 오류가 발생했습니다.");
        }
    });

    document.querySelectorAll(".admin_row_select_checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", () => {
            const row = checkbox.closest("tr");
            if (!row) {
                return;
            }
            const submission_id = (row.dataset.submissionId || "").trim();
            if (!submission_id) {
                return;
            }
            document.querySelectorAll("tr[data-submission-id]").forEach((target_row) => {
                if ((target_row.dataset.submissionId || "").trim() !== submission_id) {
                    return;
                }
                const target_checkbox = target_row.querySelector(".admin_row_select_checkbox");
                if (!target_checkbox) {
                    return;
                }
                target_checkbox.checked = checkbox.checked;
            });
        });
    });
})();
</script>
