        <label for="dropdown_delete_option_value">항목 값</label>
        <select id="dropdown_delete_option_value" name="option_value" required>
            <option value="" selected disabled hidden>항목 값을 선택하세요</option>
        </select>

        <button type="submit">항목 삭제</button>
    </form>
</section>
<script>
(() => {
    const field_select = document.getElementById("dropdown_delete_field_name");
    const option_select = document.getElementById("dropdown_delete_option_value");
    if (!field_select || !option_select) {
        return;
    }

    const fill_option_select = (option_values) => {
        option_select.innerHTML = "";
        const empty_option = document.createElement("option");
        empty_option.value = "";
        empty_option.textContent = "항목 값을 선택하세요";
        empty_option.selected = true;
        empty_option.disabled = true;
        empty_option.hidden = true;
        option_select.appendChild(empty_option);
        option_values.forEach((option_value) => {
            const option = document.createElement("option");
            option.value = option_value;
            option.textContent = option_value;
            option_select.appendChild(option);
        });
    };

    const refresh_option_values = async () => {
        const field_name = (field_select.value || "").trim();
        if (!field_name) {
            fill_option_select([]);
            return;
        }
        try {
            const response = await fetch(`/admin/dropdown_options/${encodeURIComponent(field_name)}`);
            if (!response.ok) {
                fill_option_select([]);
                return;
            }
            const payload = await response.json();
            fill_option_select(Array.isArray(payload.option_values) ? payload.option_values : []);
        } catch (_error) {
            fill_option_select([]);
        }
    };

    field_select.addEventListener("change", refresh_option_values);
    refresh_option_values();
})();
</script>

    </main>
    <script src="/static/js/app.js"></script>
</body>
</html>