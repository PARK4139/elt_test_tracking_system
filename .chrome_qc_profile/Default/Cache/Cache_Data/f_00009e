<script>
(() => {
    const save_notice = document.getElementById("admin_save_notice");
    if (!save_notice) {
        return;
    }

    const row_save_timers = new Map();

    const read_error_detail = async (response) => {
        try {
            const payload = await response.json();
            if (payload && payload.detail) {
                return payload.detail;
            }
        } catch (_error) {
        }
        return "요청에 실패했습니다.";
    };

    const render_notice = (message, type_name) => {
        save_notice.className = `non_modal_notice ${type_name}`;
        save_notice.innerHTML = `<div>${message}</div>`;
    };

    const nullable_field_names = new Set([
        "data_writer_name",
        "field_01", "field_02", "field_03", "field_04", "field_05",
        "field_06", "field_07", "field_08", "field_09", "field_10",
        "low_test_started_at", "low_test_ended_at", "low_test_delta",
        "high_test_started_at", "high_test_ended_at", "high_test_delta",
    ]);

    const build_row_payload = (row) => {
        const payload = {};
        row.querySelectorAll("input[data-field]").forEach((input) => {
            const field_name = input.dataset.field;
            const value = input.value.trim();
            payload[field_name] = nullable_field_names.has(field_name) && !value ? null : value;
        });
        return payload;
    };

    const serialize_payload = (payload) => JSON.stringify(payload);

    const is_row_dirty = (row) => {
        const current_payload = build_row_payload(row);
        const current_serialized = serialize_payload(current_payload);
        return current_serialized !== (row.dataset.initialPayload || "");
    };

    const save_row = async (row) => {
        const payload = build_row_payload(row);
        if (!is_row_dirty(row)) {
            return;
        }
        if (!payload.key_1 || !payload.key_2 || !payload.key_3) {
            render_notice("업체명, col_key_seg, 공정번호는 필수입니다.", "error");
            return;
        }

        try {
            const response = await fetch("/tester/rows/upsert", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });
            if (!response.ok) {
                render_notice(await read_error_detail(response), "error");
                return;
            }
            row.dataset.initialPayload = serialize_payload(payload);
            render_notice("수정 내용이 자동 저장되었습니다.", "success");
        } catch (_error) {
            render_notice("자동 저장 중 네트워크 오류가 발생했습니다.", "error");
        }
    };

    const schedule_row_save = (row) => {
        if (!is_row_dirty(row)) {
            return;
        }
        const existing_timer = row_save_timers.get(row);
        if (existing_timer) {
            clearTimeout(existing_timer);
        }
        const timer_id = setTimeout(() => {
            save_row(row);
            row_save_timers.delete(row);
        }, 400);
        row_save_timers.set(row, timer_id);
    };

    document.querySelectorAll("tr.admin_editable_row").forEach((row) => {
        row.dataset.initialPayload = serialize_payload(build_row_payload(row));
        row.querySelectorAll("input[data-field]").forEach((input) => {
            input.addEventListener("input", () => schedule_row_save(row));
            input.addEventListener("change", () => schedule_row_save(row));
        });
    });
})();
</script>

